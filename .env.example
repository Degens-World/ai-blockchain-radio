# ── LLM ──────────────────────────────────────────────────────────────────────
OLLAMA_MODEL=mistral-nemo:latest
OLLAMA_URL=http://localhost:11434/api/chat

# ── TTS ───────────────────────────────────────────────────────────────────────
# Kokoro voices: am_michael, am_adam, am_echo, am_fenrir, am_liam, am_onyx,
#                am_puck, af_bella, af_heart, af_nicole, af_sarah, af_sky
VOICE=am_michael
KOKORO_SPEED=1.15

# ── Streaming ─────────────────────────────────────────────────────────────────
STREAM_PORT=8234
# FFMPEG=ffmpeg   # set full path if ffmpeg is not on PATH

# ── Blockchain ────────────────────────────────────────────────────────────────
COIN_ID=ergo
EXPLORER_V1=https://api.ergoplatform.com/api/v1
EXPLORER_V0=https://api.ergoplatform.com/api/v0
ADDRESSBOOK_URL=https://api.ergexplorer.com/addressbook/getAddresses
WHALE_THRESHOLD=10000
TOKEN_ALERT_MIN=3

# ── Directories ───────────────────────────────────────────────────────────────
# HLS_DIR=./hls_output
# CLIPS_DIR=./clips
# MUSIC_DIR=./music_library

# ── Music generation (optional — requires torch + transformers + CUDA GPU) ─────
MUSICGEN_ENABLED=false
MUSICGEN_MODEL=facebook/musicgen-small
MUSIC_LIBRARY_TARGET=20
